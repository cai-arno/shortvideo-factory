# 短视频工厂 - 生产环境变量
# 复制此文件为 .env.prod 并填入实际值

# ============ 数据库 ============
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=shortvideo

# ============ Redis ============
REDIS_PASSWORD=your_redis_password_here

# ============ JWT 密钥 ============
# 生成方式: openssl rand -hex 32
SECRET_KEY=your_256bit_secret_key_here

# ============ GitHub Registry ============
# 用于 Docker 镜像拉取
GITHUB_REPOSITORY=your-org/shortvideo-factory

# ============ AI API ============
# 至少配置一个
OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ============ OSS 对象存储 ============
# 阿里云 OSS（用于素材存储）
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY=your_access_key_id
OSS_ACCESS_SECRET=your_access_key_secret
OSS_BUCKET=shortvideo-assets

# ============ 抖音开放平台 ============
DOUYIN_CLIENT_ID=your_douyin_client_id
DOUYIN_CLIENT_SECRET=your_douyin_client_secret

# ============ 服务器配置 ============
# 服务器公网 IP 或域名
SERVER_IP=your_server_ip
DOMAIN=your-domain.com
